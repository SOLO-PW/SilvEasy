<view class="container">
  <view class="header">
    <view class="title">🚌 公交查询</view>
  </view>
  
  <view class="tab-container">
    <view class="tab {{activeTab === 'nearby' ? 'active' : ''}}" bindtap="switchTab" data-tab="nearby">
      附近公交站
    </view>
    <view class="tab {{activeTab === 'line' ? 'active' : ''}}" bindtap="switchTab" data-tab="line">
      线路查询
    </view>
  </view>
  
  <view class="content">
    <view wx:if="{{activeTab === 'nearby'}}" class="nearby-container">
      <view class="refresh-btn" bindtap="refreshNearby">
        🔄 刷新位置
      </view>
      
      <view wx:if="{{loading}}" class="loading">
        <view class="loading-text">正在获取位置...</view>
      </view>
      
      <view wx:else class="station-list">
        <view wx:for="{{nearbyStations}}" wx:key="id" class="station-item">
          <view class="station-name">{{item.name}}</view>
          <view class="station-info">
            <text class="distance">📏 {{item.distance}}</text>
          </view>
          <view class="lines">
            <text wx:for="{{item.lines}}" wx:key="index" class="line-tag">{{item}}</text>
          </view>
        </view>
        
        <view wx:if="{{nearbyStations.length === 0}}" class="empty">
          <view class="empty-text">暂无公交站数据</view>
        </view>
      </view>
    </view>
    
    <view wx:if="{{activeTab === 'line'}}" class="line-container">
      <view class="search-box">
        <input class="search-input" placeholder="请输入公交线路号（如：1路）" value="{{lineNumber}}" bindinput="onInput" confirm-type="search" bindconfirm="searchLine" />
        <view class="search-btn" bindtap="searchLine">查询</view>
      </view>
      
      <view wx:if="{{lineDetail}}" class="line-detail">
        <view class="line-header">
          <view class="line-name">{{lineDetail.name}}</view>
        </view>
        <view class="line-info">
          <view class="info-item">
            <text class="info-label">起点站：</text>
            <text class="info-value">{{lineDetail.start}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">终点站：</text>
            <text class="info-value">{{lineDetail.end}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">首班车：</text>
            <text class="info-value">{{lineDetail.first}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">末班车：</text>
            <text class="info-value">{{lineDetail.last}}</text>
          </view>
        </view>
        <view class="stations-title">途经站点</view>
        <view class="stations-list">
          <view wx:for="{{lineDetail.stations}}" wx:key="index" class="station-stop">
            <view class="stop-number">{{index + 1}}</view>
            <view class="stop-name">{{item}}</view>
          </view>
        </view>
      </view>
      
      <view wx:if="{{!lineDetail && hasSearched}}" class="empty">
        <view class="empty-text">未找到该线路信息</view>
      </view>
    </view>
  </view>
</view>
