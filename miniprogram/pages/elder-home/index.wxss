.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #e4e8ec 100%);
  padding: 40rpx;
}

.header {
  background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
  border-radius: 40rpx;
  padding: 60rpx 50rpx;
  margin-bottom: 50rpx;
  box-shadow: 0 16rpx 50rpx rgba(44, 62, 80, 0.3);
}

.welcome-text {
  font-size: 72rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 30rpx;
}

.date-time {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.9);
}

.time {
  font-size: 64rpx;
  font-weight: bold;
  color: white;
}

.emergency-section {
  margin-bottom: 50rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 30rpx;
  padding-left: 10rpx;
}

.emergency-buttons {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.emergency-btn {
  width: 100%;
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 40rpx;
  border: none;
  box-shadow: 0 12rpx 40rpx rgba(231, 76, 60, 0.4);
  position: relative;
  overflow: hidden;
}

.emergency-btn::after {
  border: none;
}

.emergency-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 24rpx rgba(231, 76, 60, 0.3);
}

.emergency-btn-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.emergency-btn-name {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.emergency-btn-phone {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.95);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

.buttons-container {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.function-btn {
  width: 100%;
  height: 160rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 50rpx;
  border: none;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
  position: relative;
  overflow: hidden;
}

.function-btn::after {
  border: none;
}

.function-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

.weather-btn {
  background: linear-gradient(135deg, #4facfe 0%, #00c6fb 100%);
}

.bus-btn {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.community-btn {
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
}

.contacts-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.settings-btn {
  background: linear-gradient(135deg, #89919c 0%, #5c6370 100%);
}

.btn-icon {
  font-size: 72rpx;
  margin-right: 40rpx;
}

.btn-text {
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}