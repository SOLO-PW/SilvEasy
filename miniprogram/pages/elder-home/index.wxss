.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.header {
  background: linear-gradient(135deg, #1a237e 0%, #283593 100%);
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(26, 35, 126, 0.3);
}

.welcome-text {
  font-size: 80rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 24rpx;
  text-align: center;
}

.date-time {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.date {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}

.time {
  font-size: 72rpx;
  font-weight: bold;
  color: white;
}

.emergency-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a237e;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #1a237e;
}

.emergency-buttons {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.emergency-btn {
  width: 100%;
  background: linear-gradient(135deg, #d32f2f 0%, #b71c1c 100%);
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  border: none;
  box-shadow: 0 10rpx 32rpx rgba(211, 47, 47, 0.4);
  position: relative;
  overflow: hidden;
  min-height: 240rpx;
}

.emergency-btn::after {
  border: none;
}

.emergency-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(211, 47, 47, 0.3);
}

.emergency-btn-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.emergency-btn-name {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.emergency-btn-phone {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.98);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  font-weight: 500;
}

.buttons-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.function-btn {
  width: 100%;
  height: 180rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
  transition: all 0.2s ease;
}

.function-btn::after {
  border: none;
}

.function-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.weather-btn {
  background: linear-gradient(135deg, #1976d2 0%, #0d47a1 100%);
}

.bus-btn {
  background: linear-gradient(135deg, #388e3c 0%, #1b5e20 100%);
}

.community-btn {
  background: linear-gradient(135deg, #7b1fa2 0%, #4a148c 100%);
}

.contacts-btn {
  background: linear-gradient(135deg, #ff6f00 0%, #e65100 100%);
}

.settings-btn {
  background: linear-gradient(135deg, #616161 0%, #212121 100%);
}

.btn-icon {
  font-size: 84rpx;
  margin-right: 40rpx;
  width: 100rpx;
  text-align: center;
}

.btn-text {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
  flex: 1;
}