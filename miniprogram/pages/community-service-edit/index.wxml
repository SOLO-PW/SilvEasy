<view class="container">
  <view class="header">
    <view class="title">{{isEdit ? '编辑服务' : '添加服务'}}</view>
  </view>

  <view class="form">
    <view class="form-item">
      <view class="label">服务名称 *</view>
      <input 
        class="input" 
        placeholder="请输入服务名称" 
        value="{{name}}"
        bindinput="onNameInput"
      />
    </view>

    <view class="form-item">
      <view class="label">电话号码 *</view>
      <input 
        class="input" 
        type="number"
        placeholder="请输入电话号码" 
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-item">
      <view class="label">地址</view>
      <input 
        class="input" 
        placeholder="请输入地址（可选）" 
        value="{{address}}"
        bindinput="onAddressInput"
      />
    </view>

    <view class="form-item">
      <view class="label">服务分类</view>
      <view class="category-list">
        <view 
          wx:for="{{categories}}" 
          wx:key="id"
          class="category-item {{category === item.id ? 'active' : ''}}"
          data-category="{{item.id}}"
          bindtap="onCategoryChange"
        >
          <view class="category-icon">{{item.icon}}</view>
          <view class="category-name">{{item.name}}</view>
        </view>
      </view>
    </view>

    <view class="form-item">
      <view class="label">选择图标</view>
      <view class="icon-list">
        <view 
          wx:for="{{icons}}" 
          wx:key="*this"
          class="icon-item {{icon === item ? 'active' : ''}}"
          data-icon="{{item}}"
          bindtap="onIconSelect"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="button-wrapper">
      <button class="save-button" bindtap="onSave" disabled="{{loading}}">
        {{loading ? '保存中...' : '保存'}}
      </button>
    </view>
  </view>
</view>
