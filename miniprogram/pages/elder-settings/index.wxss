.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  color: #fff;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.content {
  padding: 0 30rpx;
}

.code-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  text-align: center;
}

.code-display {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.code-text {
  font-size: 72rpx;
  font-weight: bold;
  color: #667eea;
  letter-spacing: 16rpx;
  margin-bottom: 20rpx;
}

.expire-time {
  font-size: 26rpx;
  color: #999;
}

.empty-code {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.2;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.copy-btn {
  width: 100%;
  height: 96rpx;
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.copy-btn::after {
  border: none;
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.generate-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.generate-btn::after {
  border: none;
}

.generate-btn.disabled {
  opacity: 0.6;
}

.tips-card {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.tips-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  margin-bottom: 12rpx;
}
