.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a237e 0%, #283593 100%);
  padding-bottom: 40rpx;
}

.header {
  padding: 50rpx 40rpx 40rpx;
  color: #fff;
  text-align: center;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.subtitle {
  font-size: 32rpx;
  opacity: 0.95;
  line-height: 1.4;
}

.content {
  padding: 0 30rpx;
}

.code-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 70rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.code-display {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.code-text {
  font-size: 84rpx;
  font-weight: bold;
  color: #1a237e;
  letter-spacing: 20rpx;
  margin-bottom: 24rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.expire-time {
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
}

.empty-code {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #666;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.copy-btn {
  width: 100%;
  height: 112rpx;
  background: #fff;
  color: #1a237e;
  border: 3rpx solid #1a237e;
  border-radius: 56rpx;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.copy-btn::after {
  border: none;
}

.copy-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(26, 35, 126, 0.2);
}

.btn-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.generate-btn {
  width: 100%;
  height: 112rpx;
  background: linear-gradient(135deg, #d32f2f 0%, #b71c1c 100%);
  color: #fff;
  border-radius: 56rpx;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  transition: all 0.2s ease;
}

.generate-btn::after {
  border: none;
}

.generate-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(211, 47, 47, 0.3);
}

.generate-btn.disabled {
  opacity: 0.6;
}

.tips-card {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 28rpx;
  padding: 40rpx;
  backdrop-filter: blur(10rpx);
}

.tips-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 24rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.tips-item {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1.6;
  margin-bottom: 16rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}
