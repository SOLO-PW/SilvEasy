.container {
  min-height: 100vh;
  padding: 40rpx;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2c3e50;
}

.add-btn-container {
  margin-bottom: 40rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  height: 100rpx;
  background-color: #27ae60;
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
}

.add-btn-icon {
  font-size: 48rpx;
  line-height: 1;
}

.add-btn::after {
  border: none;
}

.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.loading-text {
  font-size: 36rpx;
  color: #666666;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999999;
}

.contact-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.contact-item {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.contact-info {
  flex: 1;
  margin-right: 30rpx;
}

.contact-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.contact-phone {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.contact-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  background-color: #e3f2fd;
  color: #1976d2;
  font-size: 24rpx;
  border-radius: 20rpx;
}

.contact-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 140rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  padding: 0;
  margin: 0;
}

.action-btn::after {
  border: none;
}

.call-btn {
  background-color: #27ae60;
  color: #ffffff;
}

.edit-btn {
  background-color: #3498db;
  color: #ffffff;
}

.delete-btn {
  background-color: #e74c3c;
  color: #ffffff;
}