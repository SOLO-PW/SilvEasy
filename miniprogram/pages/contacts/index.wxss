.container {
  min-height: 100vh;
  padding: 30rpx;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 30rpx;
  text-align: center;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #1a237e;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.add-btn-container {
  margin-bottom: 30rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #388e3c 0%, #1b5e20 100%);
  border-radius: 56rpx;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(56, 142, 60, 0.3);
  transition: all 0.2s ease;
}

.add-btn-icon {
  font-size: 56rpx;
  line-height: 1;
}

.add-btn::after {
  border: none;
}

.add-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(56, 142, 60, 0.2);
}

.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 40rpx;
}

.loading-text {
  font-size: 40rpx;
  color: #666666;
  font-weight: 500;
}

.empty-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 40rpx;
  color: #666666;
  margin-bottom: 24rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 32rpx;
  color: #999999;
}

.contact-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.contact-item {
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
}

.contact-info {
  width: 100%;
}

.contact-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.contact-phone {
  font-size: 36rpx;
  color: #666666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.contact-tag {
  display: inline-block;
  padding: 12rpx 32rpx;
  background-color: #e3f2fd;
  color: #1976d2;
  font-size: 28rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.contact-actions {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  padding: 0;
  margin: 0;
  transition: all 0.2s ease;
  text-align: center;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.call-btn {
  background: linear-gradient(135deg, #388e3c 0%, #1b5e20 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(56, 142, 60, 0.3);
}

.edit-btn {
  background: linear-gradient(135deg, #1976d2 0%, #0d47a1 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.3);
}

.delete-btn {
  background: linear-gradient(135deg, #d32f2f 0%, #b71c1c 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(211, 47, 47, 0.3);
}