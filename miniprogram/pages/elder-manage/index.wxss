.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: #f0f0f0;
  margin-right: 30rpx;
}

.info {
  flex: 1;
}

.name {
  font-size: 36rpx;
  font-weight: 500;
  color: #fff;
  margin-bottom: 8rpx;
}

.phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.content {
  padding: 30rpx;
  margin-top: -30rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 30rpx;
}

.action-list {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.action-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon-wrapper.phone {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.action-icon-wrapper.community {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
}

.emoji-icon {
  font-size: 44rpx;
}

.action-icon {
  width: 44rpx;
  height: 44rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
  word-break: break-all;
}

.danger-zone {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.danger-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #f56c6c;
  margin-bottom: 30rpx;
}

.unbind-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border: 2rpx solid #f56c6c;
  color: #f56c6c;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.unbind-btn::after {
  border: none;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
