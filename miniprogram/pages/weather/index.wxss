.container {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(180deg, #e3f2fd 0%, #bbdefb 50%, #90caf9 100%);
}

.header {
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1565c0;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 36rpx;
  color: #1565c0;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.error-text {
  font-size: 36rpx;
  color: #c62828;
  text-align: center;
  margin-bottom: 60rpx;
}

.retry-btn {
  background: #1565c0;
  color: white;
  font-size: 32rpx;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
}

.weather-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.location-row {
  display: flex;
  align-items: center;
  margin-bottom: 50rpx;
}

.location-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.location-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #263238;
  flex: 1;
}

.select-city-btn {
  background: #42a5f5;
  color: white;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  margin-left: 20rpx;
}

.weather-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.weather-icon {
  font-size: 160rpx;
  margin-bottom: 20rpx;
}

.temperature {
  font-size: 100rpx;
  font-weight: bold;
  color: #1565c0;
  margin-bottom: 10rpx;
}

.weather-status {
  font-size: 44rpx;
  color: #263238;
}

.weather-details {
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 50rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 32rpx;
  color: #546e7a;
}

.detail-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #263238;
}

.forecast-container {
  margin-bottom: 50rpx;
}

.forecast-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1565c0;
  margin-bottom: 30rpx;
  text-align: center;
}

.forecast-list {
  display: flex;
  justify-content: space-between;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
}

.forecast-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.forecast-date {
  font-size: 28rpx;
  color: #546e7a;
  margin-bottom: 10rpx;
}

.forecast-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.forecast-weather {
  font-size: 26rpx;
  color: #263238;
  margin-bottom: 8rpx;
}

.forecast-temp {
  font-size: 24rpx;
  color: #546e7a;
}

.update-time {
  font-size: 26rpx;
  color: #78909c;
  text-align: center;
  margin-bottom: 40rpx;
}

.action-buttons {
  display: flex;
  justify-content: center;
}

.refresh-btn {
  background: #1565c0;
  color: white;
  font-size: 32rpx;
  padding: 28rpx 100rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(21, 101, 192, 0.3);
}
