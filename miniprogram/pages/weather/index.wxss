.container {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(180deg, #e3f2fd 0%, #bbdefb 50%, #90caf9 100%);
}

.header {
  margin-bottom: 30rpx;
  text-align: center;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #0d47a1;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.loading-text {
  font-size: 40rpx;
  color: #0d47a1;
  font-weight: 500;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 40rpx;
}

.error-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
}

.error-text {
  font-size: 40rpx;
  color: #b71c1c;
  text-align: center;
  margin-bottom: 60rpx;
  font-weight: 500;
}

.retry-btn {
  background: linear-gradient(135deg, #1976d2 0%, #0d47a1 100%);
  color: white;
  font-size: 36rpx;
  padding: 28rpx 100rpx;
  border-radius: 56rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(25, 118, 210, 0.3);
  transition: all 0.2s ease;
}

.retry-btn::after {
  border: none;
}

.retry-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.2);
}

.weather-container {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
}

.location-row {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  flex-wrap: wrap;
  gap: 20rpx;
}

.location-icon {
  font-size: 52rpx;
  margin-right: 16rpx;
}

.location-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #263238;
  flex: 1;
}

.select-city-btn {
  background: linear-gradient(135deg, #42a5f5 0%, #1976d2 100%);
  color: white;
  font-size: 32rpx;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(66, 165, 245, 0.3);
  transition: all 0.2s ease;
}

.select-city-btn::after {
  border: none;
}

.select-city-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(66, 165, 245, 0.2);
}

.weather-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #e0e0e0;
}

.weather-icon {
  font-size: 180rpx;
  margin-bottom: 24rpx;
}

.temperature {
  font-size: 120rpx;
  font-weight: bold;
  color: #0d47a1;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.weather-status {
  font-size: 48rpx;
  color: #263238;
  font-weight: 500;
}

.weather-details {
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #e0e0e0;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 36rpx;
  color: #546e7a;
  font-weight: 500;
}

.detail-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #263238;
}

.forecast-container {
  margin-bottom: 40rpx;
}

.forecast-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #0d47a1;
  margin-bottom: 24rpx;
  text-align: center;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.forecast-list {
  display: flex;
  justify-content: space-between;
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 36rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  gap: 16rpx;
}

.forecast-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
}

.forecast-date {
  font-size: 32rpx;
  color: #546e7a;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.forecast-icon {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.forecast-weather {
  font-size: 30rpx;
  color: #263238;
  margin-bottom: 8rpx;
  text-align: center;
  font-weight: 500;
}

.forecast-temp {
  font-size: 28rpx;
  color: #546e7a;
  font-weight: 500;
}

.update-time {
  font-size: 32rpx;
  color: #78909c;
  text-align: center;
  margin-bottom: 40rpx;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  justify-content: center;
}

.refresh-btn {
  background: linear-gradient(135deg, #1976d2 0%, #0d47a1 100%);
  color: white;
  font-size: 36rpx;
  padding: 32rpx 120rpx;
  border-radius: 56rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(25, 118, 210, 0.3);
  transition: all 0.2s ease;
}

.refresh-btn::after {
  border: none;
}

.refresh-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.2);
}
