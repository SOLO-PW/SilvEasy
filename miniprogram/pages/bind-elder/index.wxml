<view class="container">
  <view class="header">
    <view class="title">绑定长辈</view>
    <view class="subtitle">请输入长辈生成的绑定码</view>
  </view>

  <view class="content">
    <view class="card">
      <view class="form-group">
        <view class="label">绑定码</view>
        <view class="input-wrapper">
          <input 
            class="bind-input" 
            type="number" 
            maxlength="6" 
            placeholder="请输入6位绑定码"
            value="{{bindCode}}"
            bindinput="onBindCodeInput"
          />
        </view>
      </view>

      <view class="form-group">
        <view class="label">关系</view>
        <picker 
          class="relation-picker" 
          mode="selector" 
          range="{{relationList}}"
          value="{{relationList.indexOf(selectedRelation)}}"
          bindchange="selectRelation"
        >
          <view class="picker-value">{{selectedRelation}}</view>
          <image class="picker-arrow" src="/images/arrow.svg" mode="aspectFit"></image>
        </picker>
      </view>
    </view>

    <view class="tips-card">
      <view class="tips-title">绑定说明</view>
      <view class="tips-item">1. 请让长辈在设置页面生成绑定码</view>
      <view class="tips-item">2. 绑定码有效期为24小时</view>
      <view class="tips-item">3. 一个绑定码只能使用一次</view>
    </view>
  </view>

  <view class="footer">
    <button 
      class="bind-btn {{loading ? 'disabled' : ''}}" 
      bindtap="bindElder"
      disabled="{{loading}}"
    >
      {{loading ? '绑定中...' : '立即绑定'}}
    </button>
  </view>
</view>
